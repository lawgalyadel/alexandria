<%- include('../partials/header') %>
<%
function formatDate(d) {
    if (!d) return '';
    return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
const longTermArticles = articles.filter((a) => a.content_type !== 'short_form');
const shortTermArticles = articles.filter((a) => a.content_type === 'short_form');
%>

    <div class="subject-page-header">
        <div class="container">
            <h1><%= subject.name %></h1>
            <% if (subject.description) { %><p><%= subject.description %></p><% } %>
        </div>
    </div>

    <div class="container">
        <div class="filter-bar">
            <label>Sort:</label>
            <select onchange="window.location.href='/subject/<%= subject.slug %>?sort='+this.value+'&type=<%= type %>'">
                <option value="newest" <%= sort==='newest'?'selected':'' %>>Newest</option>
                <option value="oldest" <%= sort==='oldest'?'selected':'' %>>Oldest</option>
                <option value="popular" <%= sort==='popular'?'selected':'' %>>Most read</option>
            </select>
            <label>Type:</label>
            <select onchange="window.location.href='/subject/<%= subject.slug %>?sort=<%= sort %>&type='+this.value">
                <option value="all" <%= type==='all'?'selected':'' %>>All</option>
                <option value="long_form" <%= type==='long_form'?'selected':'' %>>Long-form</option>
                <option value="short_form" <%= type==='short_form'?'selected':'' %>>Short-form</option>
            </select>
            <span style="margin-left:auto;font-size:0.82rem;color:var(--ink-faint)"><%= totalCount %> articles</span>
        </div>

        <% if (featured) { %>
        <section class="featured-section" style="border-bottom:none;padding-bottom:0;">
            <div class="featured-label">Featured in <%= subject.name %></div>
            <div class="featured-article reveal">
                <div class="featured-image">
                    <% if (featured.cover_image_url) { %>
                        <img src="<%= featured.cover_image_url %>" alt="" style="width:100%;height:100%;object-fit:cover;">
                    <% } %>
                </div>
                <div class="featured-content">
                    <h2 class="featured-title"><a href="/article/<%= featured.slug %>"><%= featured.title %></a></h2>
                    <p class="featured-excerpt"><%= featured.subtitle || '' %></p>
                    <div class="featured-meta">
                        <% if (featured.authors && featured.authors.length) { %>
                            <span class="author"><%= featured.authors[0].name %></span> &middot;
                        <% } %>
                        <%= formatDate(featured.publish_date) %>
                    </div>
                </div>
            </div>
        </section>
        <% } %>

        <section class="latest-section">
            <% if (type === 'all') { %>
                <div class="subject-columns">
                    <div class="subject-column">
                        <h3 class="subject-column-title">Long-form</h3>
                        <div class="article-feed">
                            <% for (const a of longTermArticles) { %>
                                <a href="/article/<%= a.slug %>" class="article-item reveal">
                                    <div class="article-item-text">
                                        <h3 class="article-item-title"><%= a.title %></h3>
                                        <p class="article-item-excerpt"><%= a.subtitle || '' %></p>
                                        <div class="article-item-meta">
                                            <% if (a.authors && a.authors.length) { %>
                                                <span class="author"><%= a.authors[0].name %></span> &middot;
                                            <% } %>
                                            <%= formatDate(a.publish_date) %>
                                        </div>
                                    </div>
                                    <% if (a.cover_image_url) { %>
                                        <img src="<%= a.cover_image_url %>" alt="" class="article-item-thumb">
                                    <% } else { %>
                                        <div class="article-item-thumb"></div>
                                    <% } %>
                                </a>
                            <% } %>
                            <% if (!longTermArticles.length) { %>
                                <p class="subject-empty">No long-form articles in this subject yet.</p>
                            <% } %>
                        </div>
                    </div>

                    <div class="subject-column">
                        <h3 class="subject-column-title">Short-form</h3>
                        <div class="article-feed">
                            <% for (const a of shortTermArticles) { %>
                                <a href="/article/<%= a.slug %>" class="article-item reveal">
                                    <div class="article-item-text">
                                        <h3 class="article-item-title"><%= a.title %></h3>
                                        <p class="article-item-excerpt"><%= a.subtitle || '' %></p>
                                        <div class="article-item-meta">
                                            <% if (a.authors && a.authors.length) { %>
                                                <span class="author"><%= a.authors[0].name %></span> &middot;
                                            <% } %>
                                            <%= formatDate(a.publish_date) %> &middot; Short-form
                                        </div>
                                    </div>
                                    <% if (a.cover_image_url) { %>
                                        <img src="<%= a.cover_image_url %>" alt="" class="article-item-thumb">
                                    <% } else { %>
                                        <div class="article-item-thumb"></div>
                                    <% } %>
                                </a>
                            <% } %>
                            <% if (!shortTermArticles.length) { %>
                                <p class="subject-empty">No short-form articles in this subject yet.</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="article-feed">
                    <% for (const a of articles) { %>
                        <a href="/article/<%= a.slug %>" class="article-item reveal">
                            <div class="article-item-text">
                                <h3 class="article-item-title"><%= a.title %></h3>
                                <p class="article-item-excerpt"><%= a.subtitle || '' %></p>
                                <div class="article-item-meta">
                                    <% if (a.authors && a.authors.length) { %>
                                        <span class="author"><%= a.authors[0].name %></span> &middot;
                                    <% } %>
                                    <%= formatDate(a.publish_date) %>
                                    <% if (a.content_type === 'short_form') { %> &middot; Short-form<% } %>
                                </div>
                            </div>
                            <% if (a.cover_image_url) { %>
                                <img src="<%= a.cover_image_url %>" alt="" class="article-item-thumb">
                            <% } else { %>
                                <div class="article-item-thumb"></div>
                            <% } %>
                        </a>
                    <% } %>
                </div>
            <% } %>

            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% if (page > 1) { %>
                        <a href="/subject/<%= subject.slug %>?sort=<%= sort %>&type=<%= type %>&page=<%= page - 1 %>">Prev</a>
                    <% } %>
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <% if (i === page) { %>
                            <span class="active"><%= i %></span>
                        <% } else { %>
                            <a href="/subject/<%= subject.slug %>?sort=<%= sort %>&type=<%= type %>&page=<%= i %>"><%= i %></a>
                        <% } %>
                    <% } %>
                    <% if (page < totalPages) { %>
                        <a href="/subject/<%= subject.slug %>?sort=<%= sort %>&type=<%= type %>&page=<%= page + 1 %>">Next</a>
                    <% } %>
                </div>
            <% } %>
        </section>
    </div>

<%- include('../partials/footer') %>
