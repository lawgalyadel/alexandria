<%- include('../partials/header') %>
<%
function formatDate(d) {
    if (!d) return '';
    const date = new Date(d);
    return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
%>

    <section class="hero">
        <div class="hero-content reveal">
            <h1><span>A Journal of Ideas</span>Alexandria</h1>
            <p class="hero-description">Rigorous analysis and thoughtful discourse across history, politics, law, economics, and philosophy.</p>
        </div>
    </section>

    <% if (featured) { %>
    <section class="featured-section">
        <div class="container">
            <div class="featured-label">Featured</div>
            <div class="featured-article reveal">
                <div class="featured-image">
                    <% if (featured.cover_image_url) { %>
                        <img src="<%= featured.cover_image_url %>" alt="<%= featured.cover_image_alt || featured.title %>" style="width:100%;height:100%;object-fit:cover;">
                    <% } %>
                </div>
                <div class="featured-content">
                    <div class="featured-subject"><%= featured.subject_names %></div>
                    <h2 class="featured-title"><a href="/article/<%= featured.slug %>"><%= featured.title %></a></h2>
                    <p class="featured-excerpt"><%= featured.subtitle || featured.body.substring(0, 200) + '...' %></p>
                    <div class="featured-meta">
                        <% if (featured.authors && featured.authors.length) { %>
                            <span class="author"><a href="/author/<%= featured.authors[0].slug %>"><%= featured.authors[0].name %></a></span> &middot;
                        <% } %>
                        <%= formatDate(featured.publish_date) %>
                    </div>
                    <a href="/article/<%= featured.slug %>" class="read-link">Continue reading
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
    <% } %>

    <!-- SUBJECTS SLIDESHOW -->
    <section class="subjects-section">
        <div class="container">
            <div class="section-label">Explore by Discipline</div>
            <div class="subjects-slideshow-wrap">
                <button class="subjects-slide-btn subjects-slide-btn--prev" id="slidePrev" aria-label="Previous">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>

                <div class="subjects-slideshow" id="subjectsSlideshow">
                    <div class="subjects-track" id="subjectsTrack">
                        <% for (const s of subjects) { %>
                        <a class="subject-slide" href="/subject/<%= s.slug %>">
                            <div class="subject-slide-icon">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                            </div>
                            <h3 class="subject-name"><%= s.name %></h3>
                            <% if (s.description) { %>
                                <p class="subject-desc"><%= s.description.substring(0, 60) %><%= s.description.length > 60 ? '…' : '' %></p>
                            <% } %>
                            <p class="subject-count"><%= subjectCounts[s.id] || 0 %> articles</p>
                        </a>
                        <% } %>
                    </div>
                </div>

                <button class="subjects-slide-btn subjects-slide-btn--next" id="slideNext" aria-label="Next">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
            </div>

            <!-- Dot indicators -->
            <div class="subjects-dots" id="subjectsDots"></div>
        </div>
    </section>

    <section class="latest-section">
        <div class="container">
            <div class="latest-header">
                <h2>Latest</h2>
            </div>
            <div class="article-feed">
                <% for (const a of latest) { %>
                    <a href="/article/<%= a.slug %>" class="article-item reveal">
                        <div class="article-item-text">
                            <div class="article-item-subject"><%= a.subject_names %></div>
                            <h3 class="article-item-title"><%= a.title %></h3>
                            <p class="article-item-excerpt"><%= a.subtitle || '' %></p>
                            <div class="article-item-meta">
                                <% if (a.authors && a.authors.length) { %>
                                    <span class="author"><%= a.authors[0].name %></span> &middot;
                                <% } %>
                                <%= formatDate(a.publish_date) %>
                            </div>
                        </div>
                        <% if (a.cover_image_url) { %>
                            <img src="<%= a.cover_image_url %>" alt="<%= a.cover_image_alt || '' %>" class="article-item-thumb">
                        <% } else { %>
                            <div class="article-item-thumb"></div>
                        <% } %>
                    </a>
                <% } %>
            </div>
        </div>
    </section>

    <section class="subscribe-banner">
        <div class="subscribe-inner">
            <h2>Stay informed</h2>
            <p>Get new articles delivered directly to your inbox. Free, no spam, unsubscribe any time.</p>
            <form class="subscribe-form" onsubmit="event.preventDefault();">
                <input type="email" placeholder="Your email address">
                <button type="submit">Subscribe</button>
            </form>
        </div>
    </section>

<%- include('../partials/footer') %>

<script>
(function () {
    const track   = document.getElementById('subjectsTrack');
    const dotsWrap = document.getElementById('subjectsDots');
    const prevBtn = document.getElementById('slidePrev');
    const nextBtn = document.getElementById('slideNext');

    if (!track) return;

    const slides = Array.from(track.querySelectorAll('.subject-slide'));
    if (!slides.length) return;

    let current   = 0;
    let autoTimer = null;

    // How many cards to show based on viewport
    function visibleCount() {
        if (window.innerWidth >= 900) return 3;
        if (window.innerWidth >= 560) return 2;
        return 1;
    }

    function maxIndex() {
        return Math.max(0, slides.length - visibleCount());
    }

    // Set slide widths dynamically so they fill the track
    function setSlideWidths() {
        const vc = visibleCount();
        const gap = 24;
        const trackWidth = track.parentElement.offsetWidth;
        const slideWidth = (trackWidth - gap * (vc - 1)) / vc;
        slides.forEach(s => {
            s.style.flex = `0 0 ${slideWidth}px`;
        });
    }

    // Rebuild dots based on number of "pages"
    function buildDots() {
        dotsWrap.innerHTML = '';
        const pages = maxIndex() + 1;
        for (let i = 0; i < pages; i++) {
            const btn = document.createElement('button');
            btn.className = 'subjects-dot' + (i === current ? ' active' : '');
            btn.setAttribute('aria-label', `Go to slide ${i + 1}`);
            btn.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); });
            dotsWrap.appendChild(btn);
        }
    }

    function goTo(index) {
        current = Math.max(0, Math.min(index, maxIndex()));

        const gap = 24;
        const slideWidth = slides[0].offsetWidth + gap;
        track.style.transform = `translateX(-${current * slideWidth}px)`;

        const dots = Array.from(dotsWrap.querySelectorAll('.subjects-dot'));
        dots.forEach((d, i) => d.classList.toggle('active', i === current));

        prevBtn.disabled = current === 0;
        nextBtn.disabled = current >= maxIndex();
    }

    function next() { goTo(current >= maxIndex() ? 0 : current + 1); }
    function prev() { goTo(current <= 0 ? maxIndex() : current - 1); }

    function startAuto() {
        stopAuto();
        autoTimer = setInterval(next, 3500);
    }
    function stopAuto() {
        if (autoTimer) clearInterval(autoTimer);
    }

    prevBtn.addEventListener('click', () => { stopAuto(); prev(); startAuto(); });
    nextBtn.addEventListener('click', () => { stopAuto(); next(); startAuto(); });

    // Touch / swipe
    let touchStartX = 0;
    track.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; stopAuto(); }, { passive: true });
    track.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) diff > 0 ? next() : prev();
        startAuto();
    });

    function init() {
        setSlideWidths();
        buildDots();
        goTo(0);
        startAuto();
    }

    window.addEventListener('resize', () => {
        setSlideWidths();
        buildDots();
        goTo(Math.min(current, maxIndex()));
    });

    init();
})();
</script>
