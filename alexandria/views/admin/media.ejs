<%- include('../partials/admin-header') %>
    <div class="admin-page-header"><h1>Media Library</h1></div>
    <div class="admin-card">
        <form method="POST" action="/admin/media/upload" enctype="multipart/form-data" style="display:flex;gap:1rem;align-items:flex-end;margin-bottom:1.5rem;">
            <div class="form-group" style="margin:0;flex:1;">
                <label>Upload Image</label>
                <input type="file" name="file" accept="image/*" required>
            </div>
            <div class="form-group" style="margin:0;flex:1;">
                <label>Alt Text</label>
                <input type="text" name="alt_text" placeholder="Describe the image">
            </div>
            <button type="submit" class="btn btn-primary">Upload</button>
        </form>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:1rem;">
            <% for (const m of media) { %>
                <div style="border:1px solid #e8e4de;border-radius:4px;overflow:hidden;">
                    <img src="/uploads/<%= m.filename %>" alt="<%= m.alt_text %>" style="width:100%;aspect-ratio:1;object-fit:cover;">
                    <div style="padding:0.5rem;font-size:0.75rem;color:#7a7a7a;">
                        <%= m.original_name %><br>
                        <code style="font-size:0.7rem;">/uploads/<%= m.filename %></code>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
<%- include('../partials/admin-footer') %>
