<%- include('../../partials/admin-header') %>

<div class="admin-page-header">
    <h1>Submissions</h1>
    <span style="font-size:0.85rem;color:var(--text-muted);"><%= submissions.length %> total</span>
</div>

<div style="display:flex;gap:0.75rem;margin-bottom:1.5rem;flex-wrap:wrap;">
    <a href="/admin/submissions" class="btn <%= !status ? 'btn-primary' : '' }" style="font-size:0.85rem;">All</a>
    <a href="/admin/submissions?status=pending" class="btn <%= status==='pending' ? 'btn-primary' : '' %>" style="font-size:0.85rem;">Pending</a>
    <a href="/admin/submissions?status=reviewing" class="btn <%= status==='reviewing' ? 'btn-primary' : '' %>" style="font-size:0.85rem;">Reviewing</a>
    <a href="/admin/submissions?status=accepted" class="btn <%= status==='accepted' ? 'btn-primary' : '' %>" style="font-size:0.85rem;">Accepted</a>
    <a href="/admin/submissions?status=rejected" class="btn <%= status==='rejected' ? 'btn-primary' : '' %>" style="font-size:0.85rem;">Rejected</a>
</div>

<div class="admin-card">
    <% if (submissions.length === 0) { %>
        <p style="color:var(--text-muted);font-size:0.95rem;padding:1rem 0;">No submissions found.</p>
    <% } else { %>
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Discipline</th>
                <th>Status</th>
                <th>Submitted</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <% for (const s of submissions) { %>
            <tr>
                <td style="font-weight:500;"><%= s.title %></td>
                <td><%= s.name %><br><span style="font-size:0.8rem;opacity:0.6;"><%= s.email %></span></td>
                <td><%= s.subject_name || '—' %></td>
                <td><span class="status-badge status-<%= s.status %>"><%= s.status %></span></td>
                <td><%= new Date(s.created_at).toLocaleDateString() %></td>
                <td><a href="/admin/submissions/<%= s.id %>">Review →</a></td>
            </tr>
            <% } %>
        </tbody>
    </table>
    <% } %>
</div>

<%- include('../../partials/admin-footer') %>
