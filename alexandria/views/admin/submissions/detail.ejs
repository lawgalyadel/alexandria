<%- include('../../partials/admin-header') %>

<div class="admin-page-header">
    <h1><%= submission.title %></h1>
    <a href="/admin/submissions" class="btn">← Back</a>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;align-items:start;">

    <div>
        <div class="admin-card" style="margin-bottom:1.5rem;">
            <h2 style="font-size:1rem;font-weight:600;margin-bottom:1rem;">Abstract</h2>
            <p style="font-size:0.95rem;line-height:1.75;white-space:pre-wrap;"><%= submission.abstract %></p>
        </div>
        <div class="admin-card">
            <h2 style="font-size:1rem;font-weight:600;margin-bottom:1rem;">Full Article</h2>
            <div style="font-size:0.9rem;line-height:1.8;white-space:pre-wrap;max-height:500px;overflow-y:auto;"><%= submission.body %></div>
        </div>
    </div>

    <div>
        <div class="admin-card" style="margin-bottom:1.5rem;">
            <h2 style="font-size:1rem;font-weight:600;margin-bottom:1rem;">Submission Details</h2>
            <table style="font-size:0.88rem;">
                <tr><td style="padding:0.4rem 0.75rem 0.4rem 0;opacity:0.6;white-space:nowrap;">Author</td><td style="padding:0.4rem 0;font-weight:500;"><%= submission.name %></td></tr>
                <tr><td style="padding:0.4rem 0.75rem 0.4rem 0;opacity:0.6;">Email</td><td style="padding:0.4rem 0;"><a href="mailto:<%= submission.email %>"><%= submission.email %></a></td></tr>
                <tr><td style="padding:0.4rem 0.75rem 0.4rem 0;opacity:0.6;">Discipline</td><td style="padding:0.4rem 0;"><%= submission.subject_name || '—' %></td></tr>
                <tr><td style="padding:0.4rem 0.75rem 0.4rem 0;opacity:0.6;">Submitted</td><td style="padding:0.4rem 0;"><%= new Date(submission.created_at).toLocaleDateString() %></td></tr>
                <tr><td style="padding:0.4rem 0.75rem 0.4rem 0;opacity:0.6;">Status</td><td style="padding:0.4rem 0;"><span class="status-badge status-<%= submission.status %>"><%= submission.status %></span></td></tr>
            </table>
        </div>

        <div class="admin-card">
            <h2 style="font-size:1rem;font-weight:600;margin-bottom:1rem;">Update Status</h2>
            <form method="POST" action="/admin/submissions/<%= submission.id %>/update" style="display:flex;flex-direction:column;gap:1rem;">
                <div>
                    <label style="font-size:0.82rem;font-weight:600;display:block;margin-bottom:0.35rem;">Status</label>
                    <select name="status" style="width:100%;padding:0.6rem 0.75rem;border:1px solid var(--border-color);border-radius:4px;background:var(--bg);font-family:inherit;font-size:0.9rem;">
                        <option value="pending" <%= submission.status==='pending' ? 'selected' : '' %>>Pending</option>
                        <option value="reviewing" <%= submission.status==='reviewing' ? 'selected' : '' %>>Reviewing</option>
                        <option value="accepted" <%= submission.status==='accepted' ? 'selected' : '' %>>Accepted</option>
                        <option value="rejected" <%= submission.status==='rejected' ? 'selected' : '' %>>Rejected</option>
                    </select>
                </div>
                <div>
                    <label style="font-size:0.82rem;font-weight:600;display:block;margin-bottom:0.35rem;">Notes</label>
                    <textarea name="admin_notes" placeholder="Internal notes…" style="width:100%;padding:0.6rem 0.75rem;border:1px solid var(--border-color);border-radius:4px;background:var(--bg);font-family:inherit;font-size:0.9rem;min-height:100px;resize:vertical;"><%= submission.admin_notes || '' %></textarea>
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;">Save</button>
            </form>
        </div>
    </div>
</div>

<%- include('../../partials/admin-footer') %>
