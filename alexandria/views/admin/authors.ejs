<%- include('../partials/admin-header') %>
    <div class="admin-page-header">
        <h1>Authors</h1>
        <a href="/admin/authors/new" class="btn btn-primary">New Author</a>
    </div>
    <div class="admin-card" style="padding:0;">
        <table>
            <thead><tr><th>Name</th><th>Articles</th><th></th></tr></thead>
            <tbody>
                <% for (const a of authors) { %>
                    <tr>
                        <td><a href="/admin/authors/<%= a.id %>/edit"><%= a.name %></a></td>
                        <td><%= a.article_count %></td>
                        <td><a href="/author/<%= a.slug %>" target="_blank" style="font-size:0.78rem;">View</a></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
<%- include('../partials/admin-footer') %>
